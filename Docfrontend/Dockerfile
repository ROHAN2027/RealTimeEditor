From node:24-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# 🌟 CATCH THE VARIABLES FROM DOCKER COMPOSE
ARG VITE_API_URL
ARG VITE_GOOGLE_CLIENT_ID
ARG VITE_GITHUB_URL
ARG VITE_LINKEDIN_URL
ARG VITE_LEETCODE_URL
ARG VITE_AVATAR_URL

# 🌟 TURN THEM INTO ENV VARIABLES FOR VITE TO READ
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
ENV VITE_GITHUB_URL=$VITE_GITHUB_URL
ENV VITE_LINKEDIN_URL=$VITE_LINKEDIN_URL
ENV VITE_LEETCODE_URL=$VITE_LEETCODE_URL
ENV VITE_AVATAR_URL=$VITE_AVATAR_URL

RUN npm run build
# RUN npm run build -- --mode development

FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html

COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]




